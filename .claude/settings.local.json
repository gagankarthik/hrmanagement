{
  "permissions": {
    "allow": [
      "Bash(npm install:*)",
      "Bash(npm run build:*)",
      "Bash(npm run dev:*)",
      "Bash(npx tsc:*)",
      "mcp__ide__getDiagnostics",
      "Bash(grep -E \"\\\\.\\(ts|js|tsx|json\\)$\")",
      "Bash(dir /s /b src\\\\app\\\\*.tsx)",
      "Bash(findstr \"page.tsx\")",
      "Bash(powershell -Command \"\\(Get-Content 'src/app/dashboard/clients/[id]/page.tsx' | Measure-Object -Line\\).Lines\")",
      "Bash(powershell -Command \"\\(Get-Content -LiteralPath 'src/app/dashboard/clients/[id]/page.tsx' | Measure-Object -Line\\).Lines\")",
      "Bash(powershell -Command \"if \\(!\\(Test-Path -LiteralPath 'src/app/dashboard/analytics'\\)\\) { New-Item -ItemType Directory -Path 'src/app/dashboard/analytics' | Out-Null; Write-Output 'created' } else { Write-Output 'exists' }\")",
      "Bash(powershell -Command \"if \\(Test-Path README.md\\) { Write-Output 'exists' } else { Write-Output 'missing' }\")"
    ]
  }
}
